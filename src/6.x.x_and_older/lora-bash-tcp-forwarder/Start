#!/bin/bash
#
# Start — lora-bash-tcp-forwarder (mPower 6.x.x)
#
# Invoked by mPower app-manager with: start | stop | restart | reload
# mPower environment variables set by app-manager:
#   APP_DIR    — installation directory of this application
#   CONFIG_DIR — directory containing the configuration files
#
# Debug tip:
#   sudo APP_DIR=$(pwd) CONFIG_DIR=$(pwd)/config ./Start start
#

NAME="lora-bash-tcp-forwarder"
DAEMON="/bin/sh"
DAEMON_ARGS="${APP_DIR}/forwarder.sh"
PID_FILE="/var/run/${NAME}.pid"
START_STOP_DAEMON="/usr/sbin/start-stop-daemon"
RUN_DIR="${APP_DIR}"

function SetEnv {
    : # no custom environment needed
}

function CreateAccess {
    # Ensure all app shell scripts are executable.
    # Needed when files were uploaded to /home and copied without +x bit.
    chmod +x "${APP_DIR}/Start" \
             "${APP_DIR}/Install" \
             "${APP_DIR}/forwarder.sh" \
             "${APP_DIR}/handle_packet.sh"
}

function ExecuteStart {
    echo "ExecuteStart:"
    $START_STOP_DAEMON --start \
                       --background \
                       --make-pidfile \
                       --pidfile "${PID_FILE}" \
                       --chdir "${RUN_DIR}" \
                       --startas "/bin/bash" \
                       -- -c "exec ${DAEMON} ${DAEMON_ARGS}"
}

function Start {
    SetEnv
    CreateAccess
    ExecuteStart
}

function Stop {
    echo "Stop:"
    $START_STOP_DAEMON --stop -p "${PID_FILE}" --retry 60
}

function Restart {
    echo "Restart:"
    Stop
    sleep 1
    Start
}

function Reload {
    echo "Reload:"
    Restart
}

case "$1" in
    start)
        echo -n "Starting $NAME: "
        Start
        ;;
    stop)
        echo -n "Stopping $NAME: "
        Stop
        ;;
    restart)
        echo -n "Restarting $NAME: "
        Restart
        ;;
    reload)
        echo -n "Reloading $NAME: "
        Reload
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|reload}" >&2
        exit 1
        ;;
esac
exit 0
